default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"] || "~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8"
    )

    begin
      current = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "co.tryqc.app"
      )
    rescue => e
      UI.message("Could not fetch latest build number: #{e.message}")
      current = 0
    end
    increment_build_number(
      build_number: current + 1,
      xcodeproj: "App.xcodeproj"
    )

    key_filepath = ENV["ASC_KEY_FILEPATH"] || File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{ENV['ASC_KEY_ID']}.p8")

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{key_filepath}' -authenticationKeyID '#{ENV['ASC_KEY_ID']}' -authenticationKeyIssuerID '#{ENV['ASC_ISSUER_ID']}'",
      export_options: {
        method: "app-store",
        teamID: ENV["APPLE_TEAM_ID"],
        signingStyle: "automatic"
      }
    )
    unless ENV["SKIP_UPLOAD"] == "true"
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true
      )
    end
  end
end
